# Databáza (Railway doplní automaticky)
DATABASE_URL=postgresql://user:password@localhost/minicrmkos

# Náhodný tajný kľúč pre session (min. 32 znakov)
# Vygenerovať: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Prihlasovacie údaje do CRM
ADMIN_USERNAME=admin
# Hash hesla — vygenerovať:
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tvojeHeslo'))"
ADMIN_PASSWORD_HASH=

# Resend (odosielanie emailov) — resend.com
RESEND_API_KEY=
# Odosielateľ — po overení domény napr. info@veselykosec.sk
# Bez overenej domény použi: onboarding@resend.dev (len na testovanie)
MAIL_FROM=onboarding@resend.dev

# Cron ochranný token — nastaviť aj na Railway
# Vygenerovať: python3 -c "import secrets; print(secrets.token_hex(16))"
CRON_SECRET=

# URL aplikácie (pre odkazy v emailoch čakacej listiny)
# napr. https://minicrmkos-production.up.railway.app
APP_URL=
