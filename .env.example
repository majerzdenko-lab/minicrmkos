# Databáza (Railway doplní automaticky)
DATABASE_URL=postgresql://user:password@localhost/minicrmkos

# Náhodný tajný kľúč pre session (min. 32 znakov)
# Vygenerovať: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Prihlasovacie údaje do CRM
ADMIN_USERNAME=admin
# Hash hesla — vygenerovať:
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tvojeHeslo'))"
